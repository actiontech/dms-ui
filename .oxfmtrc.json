{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "tabWidth": 2,
  "semi": true,
  "printWidth": 80,
  "trailingComma": "none",
  "arrowParens": "always",
  "proseWrap": "preserve",
  "useTabs": false,
  "singleQuote": true,
  "bracketSpacing": true,
  "jsxBracketSameLine": false,
  "sortPackageJson": false,
  "ignorePatterns": [
    "*.snap",
    "*.md"
  ]
}
