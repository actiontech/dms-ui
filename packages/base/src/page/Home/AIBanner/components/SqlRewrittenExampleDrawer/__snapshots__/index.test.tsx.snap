                                <input
                                  height="500"
                                  language="sql"
                                  modified="(SELECT test.u.id, test.u.name, test.u.email, test.u.created_at, test.u.status,
test.o.id AS order_id, test.o.amount, test.o.description, test.o.status AS order_status, test.o.created_at AS order_created_at,
test.p.id AS payment_id, test.p.status AS payment_status, test.p.payment_method, test.p.created_at AS payment_created_at
FROM test.users test.u
JOIN test.orders test.o ON test.u.id = test.o.user_id AND test.o.status = 'COMPLETED' AND test.o.user_id > 0
JOIN test.payments test.p ON test.u.id = test.p.user_id AND test.p.user_id > 0
WHERE test.u.id > 0 AND test.u.created_at BETWEEN '2023-01-01' AND '2023-12-31 23:59:59'
AND test.o.amount > '100'
AND test.p.status IS NOT NULL
AND test.o.description LIKE '%test%'
ORDER BY test.p.created_at DESC)
UNION ALL
(SELECT test.u.id, test.u.name, test.u.email, test.u.created_at, test.u.status,
test.o.id AS order_id, test.o.amount, test.o.description, test.o.status AS order_status, test.o.created_at AS order_created_at,
test.p.id AS payment_id, test.p.status AS payment_status, test.p.payment_method, test.p.created_at AS payment_created_at
FROM test.users test.u
JOIN test.orders test.o ON test.u.id = test.o.user_id AND test.o.status = 'COMPLETED' AND test.o.user_id > 0
JOIN test.payments test.p ON test.u.id = test.p.user_id AND test.p.user_id > 0
WHERE test.u.id > 0 AND test.u.created_at BETWEEN '2023-01-01' AND '2023-12-31 23:59:59'
AND test.o.amount > '100'
AND test.p.status IS NOT NULL
AND test.u.email LIKE '%example%'
ORDER BY test.p.created_at DESC)
LIMIT 1000 OFFSET 500;"
                                  options="{"automaticLayout":true,"minimap":{"enabled":false},"fontFamily":"SF Mono","fontSize":14,"fontWeight":"400","lineNumbersMinChars":2,"suggestFontSize":14,"scrollBeyondLastLine":false,"lineHeight":24,"letterSpacing":0.8,"overviewRulerBorder":false,"wordWrap":"on","wrappingStrategy":"advanced","wrappingIndent":"indent","scrollbar":{"vertical":"visible","horizontal":"visible","useShadows":false,"verticalScrollbarSize":12,"horizontalScrollbarSize":12,"alwaysConsumeMouseWheel":false},"folding":false,"lineNumbers":"on","glyphMargin":false,"lineDecorationsWidth":50,"renderValidationDecorations":"on","guides":{"indentation":true,"highlightActiveIndentation":true},"renderOverviewRuler":false,"readOnly":true}"
                                  original="SELECT *
FROM users u
JOIN orders o ON u.id = o.user_id AND UPPER(o.status) = 'COMPLETED'
JOIN payments p ON u.id = p.user_id
WHERE YEAR(u.created_at) = 2023
AND o.amount > '100'
AND p.status IS NOT NULL
AND o.description LIKE '%test%'
OR LOWER(u.email) LIKE '%example%'
ORDER BY RAND(), p.created_at DESC
LIMIT 1000 OFFSET 500;"
                                  theme="editorCustomTheme"
                                  value=""
